# Chave de API da Anthropic — necessária para o motor de captura (visão).
# Obtenha em https://console.anthropic.com/
ANTHROPIC_API_KEY=

# String de conexão do Postgres. Sem isso, o Prisma não conecta a nenhum banco real
# (o schema existe, mas a persistência ainda não foi ligada neste protótipo).
DATABASE_URL=postgresql://user:password@localhost:5432/fluxo

# Porta do servidor Fastify.
PORT=3000
