// Schema do FLUXO — ver golden source, seções 3.5/3.12/3.13/5.2.
// Conectado a um Supabase Postgres live (ver CLAUDE.md > Infrastructure). DDL é
// aplicado via MCP do Supabase / dashboard, NÃO via `prisma migrate`/`db push`:
// a DATABASE_URL aponta para o transaction pooler (6543), que não suporta DDL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RegimeTributario {
  MEI
  SIMPLES
  CARNE_LEAO
}

enum TipoLancamento {
  RECEITA
  DESPESA
}

enum BaldeTipo {
  SALARIO
  IMPOSTO
  RESERVA
  REINVESTIMENTO
}

enum OrigemLancamento {
  CAMERA
  GALERIA
  IMPORT
  MANUAL
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nome      String?
  regime    RegimeTributario?

  // Coletados no onboarding (Fluxo 1 / US-001/US-002). Nullable porque o usuário
  // pode "começar sem dados" e preencher depois (ver mockup, passo 5 do onboarding).
  tipoTrabalho String? // ex. "Design", "Dev / Tech" — texto livre vindo dos chips
  metaSalario  Float? // salário-alvo mensal; usado para o % da meta no Dashboard (US-005)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries       Entry[]
  bucketConfig  BucketConfig?
  despesasFixas DespesaFixa[]
}

/// Despesa recorrente mensal (aluguel, ferramentas, internet…). Insumo do
/// cálculo de fôlego/runway no Dashboard. Ver golden source 3.5/5.2 e mockup §3.9.
model DespesaFixa {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  descricao String
  valor     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Configuração de baldes do usuário (% de cada recebimento que vai para cada balde).
/// Ver seção 3.5 "Configuração de baldes".
model BucketConfig {
  id        String @id @default(uuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  percentSalario        Float @default(0.5)
  percentImposto         Float @default(0.15)
  percentReserva         Float @default(0.25)
  percentReinvestimento  Float @default(0.1)

  updatedAt DateTime @updatedAt
}

/// Um lançamento — pode ter vindo do motor de captura (câmera/imagem) ou de
/// entrada manual. Campos de captura ficam null quando origem = MANUAL.
model Entry {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])

  valor       Float
  data        DateTime
  tipo        TipoLancamento
  categoria   String?
  descricao   String?
  balde       BaldeTipo?

  origem            OrigemLancamento
  imagemUrl         String? // path/URL da imagem original, se origem != MANUAL
  confiancaCaptura  String? // "alta" | "media" | "baixa" — só relevante p/ capturas via imagem
  confirmadoPeloUsuario Boolean @default(false) // nunca true automaticamente — ver princípio de confiança, 3.13

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
